#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROGRAM_DIR="$ROOT_DIR/docs/marketing/programs"
README_PATH="$ROOT_DIR/README.md"
ASSET_DIR="$ROOT_DIR/docs/marketing/generated/final"
COPY_PACK_PATH="$ASSET_DIR/launch-copy-pack.md"

fail() {
    echo "marketing verify: $*" >&2
    exit 1
}

require_file() {
    local path="$1"
    [[ -s "$path" ]] || fail "missing or empty file: ${path#$ROOT_DIR/}"
}

require_contains() {
    local path="$1"
    local pattern="$2"
    local label="$3"
    if ! grep -Eiq "$pattern" "$path"; then
        fail "missing ${label} in ${path#$ROOT_DIR/}"
    fi
}

require_not_contains() {
    local path="$1"
    local pattern="$2"
    local label="$3"
    if grep -Eiq "$pattern" "$path"; then
        fail "unexpected ${label} in ${path#$ROOT_DIR/}"
    fi
}

count_heading_occurrences() {
    local path="$1"
    local heading_text="$2"
    python3 - "$path" "$heading_text" <<'PY'
import re
import sys
from pathlib import Path

path = Path(sys.argv[1])
heading_text = sys.argv[2].strip().lower()
count = 0
for line in path.read_text().splitlines():
    match = re.match(r'^(#{1,6})\s+(.*)$', line.strip())
    if not match:
        continue
    heading = re.sub(r'\s+', ' ', match.group(2).strip()).lower()
    if heading == heading_text:
        count += 1
print(count)
PY
}

count_section_items() {
    local path="$1"
    local heading_pattern="$2"
    python3 - "$path" "$heading_pattern" <<'PY'
import re
import sys
from pathlib import Path

path = Path(sys.argv[1])
heading = re.compile(sys.argv[2], re.I)
count = 0
table_rows = 0
in_section = False
for line in path.read_text().splitlines():
    if heading.search(line):
        in_section = True
        continue
    if in_section and re.match(r'^#{1,6}\s+', line):
        break
    if not in_section:
        continue
    if re.match(r'^\s*(?:[-*]|\d+\.)\s+', line):
        count += 1
        continue
    if re.match(r'^\|', line) and not re.match(r'^\|(?:\s*:?-+:?\s*\|)+\s*$', line):
        table_rows += 1
if table_rows:
    count += max(0, table_rows - 1)
print(count)
PY
}

positioning_files=()
while IFS= read -r positioning_candidate; do
    positioning_files+=("$positioning_candidate")
done < <(find "$PROGRAM_DIR" -maxdepth 1 -type f -name '*-positioning.md' | sort)
[[ ${#positioning_files[@]} -gt 0 ]] || fail "missing docs/marketing/programs/*-positioning.md"

selected_prefix=""
positioning_path=""
asset_direction_path=""
launch_plan_path=""
for positioning_candidate in "${positioning_files[@]}"; do
    prefix="${positioning_candidate%-positioning.md}"
    asset_candidate="${prefix}-asset-direction.md"
    launch_candidate="${prefix}-launch-plan.md"
    if [[ -f "$asset_candidate" && -f "$launch_candidate" ]]; then
        selected_prefix="$prefix"
        positioning_path="$positioning_candidate"
        asset_direction_path="$asset_candidate"
        launch_plan_path="$launch_candidate"
    fi
done

[[ -n "$selected_prefix" ]] || fail "missing matching asset-direction/launch-plan docs for a marketing program run"

require_file "$positioning_path"
require_file "$asset_direction_path"
require_file "$launch_plan_path"

require_contains "$positioning_path" 'who .*use' 'who-should-use answer'
require_contains "$positioning_path" 'why .*trust' 'why-trust answer'
require_contains "$positioning_path" 'why .*download|why .*now' 'why-download-now answer'
require_contains "$positioning_path" 'skeptical' 'skeptical user section'
require_contains "$positioning_path" 'bounce|severity|rank' 'bounce severity ranking'
require_contains "$positioning_path" 'must' 'must priorities'
require_contains "$positioning_path" 'should' 'should priorities'
require_contains "$positioning_path" 'could' 'could priorities'

conversion_blockers_count="$(count_section_items "$positioning_path" 'conversion blockers')"
if [[ "$conversion_blockers_count" -lt 5 ]]; then
    fail "expected at least 5 conversion blockers in ${positioning_path#$ROOT_DIR/}; found $conversion_blockers_count"
fi

require_contains "$asset_direction_path" 'screenshot' 'screenshot direction'
require_contains "$asset_direction_path" 'gif|video|demo' 'gif/video direction'
require_contains "$launch_plan_path" 'github' 'GitHub launch copy'
require_contains "$launch_plan_path" 'reddit' 'Reddit launch copy'
require_contains "$launch_plan_path" 'hacker news|hn\b' 'Hacker News launch copy'

require_file "$README_PATH"
require_contains "$README_PATH" 'readme-hero\.png' 'README hero asset reference'
require_contains "$README_PATH" 'layoutrecall-demo\.(gif|mp4)' 'README demo asset reference'
faq_count="$(count_heading_occurrences "$README_PATH" "FAQ")"
if [[ "$faq_count" -ne 1 ]]; then
    fail "expected exactly 1 FAQ heading in README.md; found $faq_count"
fi

MARKETING_README_PATH="$ROOT_DIR/docs/marketing/README.md"
require_file "$MARKETING_README_PATH"
require_contains "$MARKETING_README_PATH" 'launch-copy-pack\.md' 'marketing README copy-pack reference'
require_not_contains "$MARKETING_README_PATH" 'launch-copy\.md' 'stale launch-copy.md reference'

for asset in \
    readme-hero.png \
    readme-feature-trust.png \
    readme-feature-profiles.png \
    social-card.png \
    layoutrecall-demo.gif \
    layoutrecall-demo.mp4; do
    require_file "$ASSET_DIR/$asset"
done

require_file "$COPY_PACK_PATH"
require_contains "$COPY_PACK_PATH" 'primary audience|MacBook \+ dock' 'copy-pack audience framing'
require_contains "$COPY_PACK_PATH" 'confidence is high|confident' 'copy-pack trust framing'
require_contains "$COPY_PACK_PATH" 'GitHub release|repo announcement' 'copy-pack GitHub section'
require_contains "$COPY_PACK_PATH" 'Reddit post' 'copy-pack Reddit section'
require_contains "$COPY_PACK_PATH" 'Hacker News|Show HN' 'copy-pack Hacker News section'
require_contains "$COPY_PACK_PATH" 'readme-hero\.png' 'copy-pack hero asset reference'
require_contains "$COPY_PACK_PATH" 'layoutrecall-demo\.(gif|mp4)' 'copy-pack demo asset reference'
require_contains "$COPY_PACK_PATH" 'social-card\.png' 'copy-pack social asset reference'

echo "marketing verify: PASS (${selected_prefix#$ROOT_DIR/})"
