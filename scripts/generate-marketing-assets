#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SCRATCH_PATH="${SCRATCH_PATH:-$HOME/Library/Caches/layoutrecall-marketing-build}"
OUTPUT_ROOT="${1:-$ROOT_DIR/docs/marketing/generated}"
RAW_DIR="$OUTPUT_ROOT/raw-ui"
FINAL_DIR="$OUTPUT_ROOT/final"

mkdir -p "$RAW_DIR" "$FINAL_DIR"
rm -f "$RAW_DIR"/*.png
rm -f "$FINAL_DIR"/*.png "$FINAL_DIR"/*.gif "$FINAL_DIR"/*.mp4 "$FINAL_DIR"/slides.txt

echo "[1/4] Rendering UI snapshots..."
(
    cd "$ROOT_DIR"
    LAYOUTRECALL_SNAPSHOT_OUTPUT_DIR="$RAW_DIR" \
    swift test --filter renderMenuAndSettingsSnapshots --scratch-path "$SCRATCH_PATH"
)

echo "[2/4] Building branded stills..."
swift "$ROOT_DIR/scripts/marketing_compositor.swift" "$RAW_DIR" "$FINAL_DIR"

echo "[3/4] Encoding demo video..."
ffmpeg -y \
    -loop 1 -t 2.4 -i "$FINAL_DIR/slide-01.png" \
    -loop 1 -t 2.4 -i "$FINAL_DIR/slide-02.png" \
    -loop 1 -t 2.4 -i "$FINAL_DIR/slide-03.png" \
    -filter_complex "[0:v]fps=30,format=yuv420p,scale=1600:900,setsar=1[v0]; \
                     [1:v]fps=30,format=yuv420p,scale=1600:900,setsar=1[v1]; \
                     [2:v]fps=30,format=yuv420p,scale=1600:900,setsar=1[v2]; \
                     [v0][v1]xfade=transition=fade:duration=0.4:offset=2.0[x1]; \
                     [x1][v2]xfade=transition=fade:duration=0.4:offset=4.0[v]" \
    -map "[v]" \
    -c:v libx264 -pix_fmt yuv420p \
    "$FINAL_DIR/layoutrecall-demo.mp4"

echo "[4/4] Encoding GIF..."
ffmpeg -y \
    -i "$FINAL_DIR/layoutrecall-demo.mp4" \
    -vf "fps=12,scale=1200:-1:flags=lanczos,split[s0][s1];[s0]palettegen=max_colors=128[p];[s1][p]paletteuse=dither=bayer" \
    "$FINAL_DIR/layoutrecall-demo.gif"

echo
echo "Marketing assets written to:"
echo "  $FINAL_DIR"
